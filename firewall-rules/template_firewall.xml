<?xml version="1.0"?>
<pfsense>
	<version>23.4</version>
	<filter>
		<rule>
			<type>pass</type>
			<interface>lan</interface>
			<ipproto>inet</ipproto>
			<protocol>tcp</protocol>
			<source>
				<network>lannet</network>
			</source>
			<destination>
				<address>10.0.20.10</address>
				<port>443</port>
			</destination>
			<descr><![CDATA[LAN to DMZ - HTTPS Access]]></descr>
			<log></log>
		</rule>
		<separator>
			<lan></lan>
			<wan></wan>
		</separator>
	</filter>
</pfsense>
